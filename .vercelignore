# Exclude data ingestion scripts and tools from Vercel deployment
data_ingestion/
data_ingestion/**

# Exclude test files
test-*.ts
test_*.py
*.ipynb

# Exclude Python-specific files and runtime data (not needed for Next.js deployment)
chromadb_api.py
requirements.txt
data/
*.log
*.session
tele_extracted*.json

# Exclude Python cache and databases
__pycache__/
**/__pycache__/
*.pyc
*.db
*.sqlite
*.sqlite3

# Exclude documentation (optional - uncomment if you don't want to deploy docs)
# DEPLOYMENT.md
# IMPLEMENTATION_SUMMARY.md
# PROJECT_COMPLETE.md
# QUICKSTART.md

# Exclude git files
.git/
.gitignore
